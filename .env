APP_NAME=Speech Intelligence API
APP_VERSION=1.0.0
API_V1_PREFIX=/api/v1
HOST=0.0.0.0
PORT=7500
DEBUG=false
ENVIRONMENT=development
LOG_LEVEL=INFO
TEMP_DIR=app/temp
CORS_ALLOW_ORIGINS=*
CORS_ALLOW_CREDENTIALS=true
MAX_UPLOAD_SIZE_MB=25
WHISPER_MODEL_SIZE=base
WHISPER_COMPUTE_TYPE=int8
DEFAULT_LANGUAGE=en
SENTIMENT_MODEL_NAME=cardiffnlp/twitter-xlm-roberta-base-sentiment
IDEAL_WORDS_PER_MINUTE=130
FILLER_THRESHOLD=5
LONG_PAUSE_THRESHOLD_SEC=1.5
PAUSE_GAP_THRESHOLD_SEC=0.8
